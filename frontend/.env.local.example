# Get a free Groq API key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GROQ_CODE_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_DEFAULT_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
GROQ_CODE_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant

# Get a Vercel API token at https://vercel.com/account/tokens (for auto-deploy)
VERCEL_TOKEN=your_vercel_token_here
VERCEL_DEPLOY_API_URL=https://api.vercel.com/v13/deployments

# Backend URL used by the Next.js rewrite layer
BACKEND_URL=http://127.0.0.1:8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
